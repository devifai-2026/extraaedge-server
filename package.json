{
  "name": "extraaedge-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ExtraaEdge Admin backend — multi-tenant educational CRM (Node + Express + Postgres, DB-per-tenant).",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "nodemon --watch src src/index.js",
    "start": "node src/index.js",
    "setup": "node scripts/setup-local.js",
    "migrate:system": "node scripts/run-migrations.js --target system",
    "migrate:tenant": "node scripts/run-migrations.js --target tenant",
    "provision:tenant": "node scripts/provision-tenant.js",
    "create:product-owner": "node scripts/create-product-owner.js",
    "seed:dev": "node scripts/seed-dev.js",
    "backup": "bash scripts/backup-all-dbs.sh",
    "worker:all": "node src/workers/run-all.js",
    "worker:email": "node src/workers/email-sender.js",
    "worker:sms": "node src/workers/sms-sender.js",
    "worker:whatsapp": "node src/workers/whatsapp-sender.js",
    "worker:notifications": "node src/workers/notification-worker.js",
    "worker:bulk-import": "node src/workers/bulk-import-worker.js",
    "worker:bulk-export": "node src/workers/bulk-export-worker.js",
    "worker:campaigns": "node src/workers/campaign-runner.js",
    "worker:drip": "node src/workers/drip-scheduler.js",
    "worker:scheduled-sends": "node src/workers/scheduled-send-runner.js",
    "worker:workflows": "node src/workers/workflow-executor.js",
    "worker:rules": "node src/workers/rule-processor.js",
    "worker:webhooks": "node src/workers/outbound-webhook-dispatcher.js",
    "worker:pdf": "node src/workers/pdf-report-worker.js",
    "worker:duplicates": "node src/workers/duplicate-scanner.js",
    "worker:followup-reminders": "node src/workers/followup-reminder-scheduler.js",
    "worker:missed-followups": "node src/workers/missed-followup-scanner.js",
    "worker:sla": "node src/workers/sla-scanner.js",
    "worker:referrals": "node src/workers/referral-crediter.js",
    "worker:attribution": "node src/workers/attribution-snapshotter.js",
    "worker:touches": "node src/workers/touch-recorder.js",
    "test": "node --test tests/**/*.test.js",
    "test:integration": "node --test tests/integration/**/*.test.js",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "lint": "eslint src scripts tests",
    "format": "prettier --write src scripts tests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.632.0",
    "@aws-sdk/s3-request-presigner": "^3.632.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.20.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.1.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.0.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "node-pg-migrate": "^7.6.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "prom-client": "^15.1.3",
    "rrule": "^2.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.12.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3"
  }
}
